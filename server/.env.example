PORT=5000
MONGODB_URI=your_mongodb_atlas_connection_string_here
NODE_ENV=production
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here
JWT_SECRET=your_secure_jwt_crypto_secret_here

# CRITICAL: Set this to the EXACT redirect URI registered in Google Cloud Console.
# For Railway production deployment:
GOOGLE_CALLBACK_URL=https://tesserio.up.railway.app/api/auth/google/callback

# The Vercel frontend URL. Used for post-auth redirects and CORS origin allowlist.
CLIENT_URL=https://your-vercel-app.vercel.app
FRONTEND_URL=https://your-vercel-app.vercel.app